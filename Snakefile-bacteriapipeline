#----SET VARIABLES----#

PROJ = config["proj_name"]
INPUTDIR = config["input_dir"]
SCRATCH = config["scratch"]
OUTPUTDIR = config["outputDIR"]
UNTRIMMEDDIR = config["untrimmed_raw_data"]
PCT = config["pct"]

#----PIPELINE----#
if PCT != 100:
  PROJ = f"{PROJ}_{PCT}"
INPUTDIR_new = f"{SCRATCH}/{INPUTDIR}_{PCT}"
UNTRIMMEDDIR_new = f"{SCRATCH}/{UNTRIMMEDDIR}_{PCT}"
print("PROJECT NAME:", file=sys.stderr)
print(PROJ, file=sys.stderr)

# Create base directories
os.makedirs(SCRATCH, exist_ok=True)
os.makedirs(OUTPUTDIR, exist_ok=True)

rule all:
  input:
    os.path.join(OUTPUTDIR, PROJ, "final_output", PROJ + "-asv-table.tsv"),
    os.path.join(OUTPUTDIR, PROJ, "final_output", PROJ + "-taxonomy.tsv"),
    os.path.join(OUTPUTDIR, PROJ, "final_output", PROJ + "-rep-seqs.fasta"),
    os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-demultiplexed-seqs.qzv"),
    os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-taxa-barplots.qzv"),
    os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-denoising-stats.qzv")

rule subsample_reads:
  output:
    fwd = os.path.join(INPUTDIR_new, "forward.fastq.gz"),
    rev = os.path.join(INPUTDIR_new, "reverse.fastq.gz")
  params:
    pct = PCT
  shell:
    """
    mkdir -p {INPUTDIR_new}
    mkdir -p {UNTRIMMEDDIR_new}

    if [ {params.pct} -eq 100 ]; then
      # Copy all original reads to temp dir
      cp {INPUTDIR}/*_1*.fq.gz {UNTRIMMEDDIR_new}/
      cp {INPUTDIR}/*_2*.fq.gz {UNTRIMMEDDIR_new}/
    else
      # Subsample reads using vsearch into temp dir
      for f in {INPUTDIR}/*_1*.fq.gz; do
        base=$(basename $f)
        vsearch --fastx_subsample $f \
          --fastqout - \
          --sample_pct {params.pct} \
          --randseed 2018 | gzip -c > {UNTRIMMEDDIR_new}/$base
      done
      for f in {INPUTDIR}/*_2*.fq.gz; do
        base=$(basename $f)
        vsearch --fastx_subsample $f \
          --fastqout - \
          --sample_pct {params.pct} \
          --randseed 2018 | gzip -c > {UNTRIMMEDDIR_new}/$base
      done
    fi

    # Pick first forward/reverse read as canonical files
    first_fwd=$(ls {UNTRIMMEDDIR_new}/*_1*.fq.gz | head -n1)
    first_rev=$(ls {UNTRIMMEDDIR_new}/*_2*.fq.gz | head -n1)

    cp $first_fwd {output.fwd}
    cp $first_rev {output.rev}
    """

rule qiime_import:
  input:
    fwd = os.path.join(INPUTDIR_new,"forward.fastq.gz"),
    rev = os.path.join(INPUTDIR_new,"reverse.fastq.gz")
  output:
    q2_import = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-multiplexed-seqs.qza")
  params:
    input_dir = os.path.join(INPUTDIR_new)
  log:
    os.path.join(SCRATCH, "qiime2", "logs", PROJ, PROJ + "_q2_import.log")
  shell:
   """
   qiime tools import \
       --type 'MultiplexedPairedEndBarcodeInSequence' \
       --input-path {params.input_dir} \
       --output-path {output.q2_import} > {log} 2>&1
   """

#############################################
# Rule: Demultiplex reads

# Change between the 2024.10 and 2026.1 version
# added:
# --p-forward-cut {params.barcode_cut} \
# --p-forward-cut {params.barcode_cut} \
# this allows removing the 2 bp (AC) at the beginning
# in the same step as deumltiplexing

#############################################
rule qiime_demux:
  input:
    q2_import = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-multiplexed-seqs.qza"),
    mapping_file = config["mappingfile"]
  output:
    q2_demux_file = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-demultiplexed-seqs.qza"),
    q2_demux_untrimmed = os.path.join(SCRATCH, "qiime2", PROJ, PROJ + "-untrimmed-demultiplexed-seqs.qza")
  threads: 
    config["cutadapt_cores"]
  params:
    batch_size = config["cutadapt_batch"],
    error_rate = config["cutadapt_error_rate"],
    barcode_cut = config["barcode_cut"]
  log:
    os.path.join(SCRATCH, "qiime2", "logs", PROJ, PROJ + "_q2_demux.log")
  shell:
   """
   qiime cutadapt demux-paired \
       --i-seqs {input.q2_import} \
       --p-error-rate {params.error_rate} \
       --m-forward-barcodes-file {input.mapping_file} \
       --m-reverse-barcodes-file {input.mapping_file} \
       --m-forward-barcodes-column Forward_Barcode \
       --m-reverse-barcodes-column Reverse_Barcode \
       --p-forward-cut {params.barcode_cut} \
       --p-reverse-cut {params.barcode_cut} \
       --o-per-sample-sequences {output.q2_demux_file} \
       --p-mixed-orientation TRUE \
       --p-anchor-forward-barcode TRUE \
       --p-anchor-reverse-barcode TRUE \
       --p-batch-size {params.batch_size} \
       --p-cores {threads} \
       --verbose \
       --o-untrimmed-sequences {output.q2_demux_untrimmed} > {log} 2>&1
   """

rule qiime_summarize:
  input:
    q2_demux_file = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-demultiplexed-seqs.qza")
  output:
    q2_qzv_file = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-demultiplexed-seqs.qzv")
  log:
    os.path.join(SCRATCH, "qiime2", "logs", PROJ, PROJ + "_q2_demux_summarize.log")
  shell:
   """
   qiime demux summarize \
    --i-data {input.q2_demux_file} \
    --o-visualization {output.q2_qzv_file} > {log} 2>&1
   """


rule qiime_trim:
  input:
    q2_demux_file = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-demultiplexed-seqs.qza")
  output:
    q2_trimmed_file = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-demultiplexed-seqs-trimmed.qza")
  threads: 
    config["cutadapt_cores"]
  params:
    primerF = config["primerF"],
    primerR = config["primerR"],
    primer_err = config["primer_err"],
    overlap = config["primer_overlap"]
  log:
    os.path.join(SCRATCH, "qiime2", "logs", PROJ, PROJ + "_q2_demux_trim.log")
  shell:
   """
   qiime cutadapt trim-paired \
      --i-demultiplexed-sequences {input.q2_demux_file} \
      --p-front-f {params.primerF} \
      --p-front-r {params.primerR} \
      --p-cores {threads} \
      --p-error-rate {params.primer_err} \
      --p-discard-untrimmed \
      --p-overlap {params.overlap} \
      --o-trimmed-sequences {output.q2_trimmed_file} > {log} 2>&1
   """

rule qiime_trim_summarize:
  input:
    q2_trimmed_file = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-demultiplexed-seqs-trimmed.qza")
  output:
    q2_trimmed_viz = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-demultiplexed-seqs-trimmed.qzv")
  log:
    os.path.join(SCRATCH, "qiime2", "logs", PROJ, PROJ + "_q2_trim_summarize.log")
  shell:
   """
   qiime demux summarize \
      --i-data {input.q2_trimmed_file} \
      --o-visualization {output.q2_trimmed_viz} > {log} 2>&1
   """

#############################################
# Rule: Denoise and merge reads

# Change between the 2024.10 and 2026.1 version
# added parameters required in the 2026.1 version
# both set to default values
# --p-max-merge-mismatch 0 \ only exact overlaps are allowed (like it was in the past implicitly)
# --p-trim-overhang False \ overhanfs in the alignment after merging are not trimmed off
# new output: base_transition_stats A table listing the transition rates of each ordered pair of nucleotides at each quality score.
#############################################
rule qiime_denoise:
  input:
    q2_trimmed_file = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-demultiplexed-seqs-trimmed.qza")
  output:
    q2_denoised_table = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-table.qza"),
    q2_denoised_file = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-representative-sequences.qza"),
    q2_denoised_stats = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-denoising-stats.qza"),
    q2_base_transition_stats = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-base-transition-stats.qza")
  threads:
    config["q2_cores"]
  log:
    os.path.join(SCRATCH, "qiime2", "logs", PROJ, PROJ + "_q2_dada2_denoise.log")
  params:
    trunc_len_f = config["trunc_len_f"],
    trunc_len_r = config["trunc_len_r"],
    max_ee_f = config["max_ee_f"],
    max_ee_r = config["max_ee_r"]
  shell:
    """
    qiime dada2 denoise-paired \
      --i-demultiplexed-seqs {input.q2_trimmed_file} \
      --p-trunc-len-f {params.trunc_len_f} \
      --p-trunc-len-r {params.trunc_len_r} \
      --p-trim-left-f 0 \
      --p-trim-left-r 0 \
      --p-max-ee-f {params.max_ee_f} \
      --p-max-ee-r {params.max_ee_r} \
      --p-trunc-q 2 \
      --p-min-overlap 12 \
      --p-max-merge-mismatch 0 \
      --p-trim-overhang False \
      --p-pooling-method independent \
      --p-chimera-method consensus \
      --p-min-fold-parent-over-abundance 1.0 \
      --p-allow-one-off False \
      --p-n-threads {threads} \
      --p-n-reads-learn 1000000 \
      --p-hashed-feature-ids \
      --p-retain-all-samples True \
      --o-representative-sequences {output.q2_denoised_file} \
      --o-table {output.q2_denoised_table} \
      --o-denoising-stats {output.q2_denoised_stats} \
      --o-base-transition-stats {output.q2_base_transition_stats} > {log} 2>&1
    """
    
rule qiime_denoise_stats_visualize:
