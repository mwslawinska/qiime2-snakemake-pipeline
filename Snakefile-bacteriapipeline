      --m-input-file {input.q2_denoised_stats} \
      --o-visualization {output.q2_denoised_stats_viz} > {log} 2>&1
  """

rule qiime_classify:
  input:
    q2_denoised_file = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-representative-sequences.qza"),
    classifier = config["qiime_classifier"]
  output:
    q2_classification = os.path.join(OUTPUTDIR, PROJ, "qiime2", PROJ + "-taxonomy.qza")
  threads:
    config["q2_cores"]
  log:
    os.path.join(SCRATCH, "qiime2", "logs", PROJ, PROJ + "_q2_classify.log")
  shell:
   """
   qiime feature-classifier classify-sklearn \
      --i-classifier {input.classifier} \
      --i-reads {input.q2_denoised_file} \
      --o-classification {output.q2_classification} \
      --p-n-jobs {threads} > {log} 2>&1
    """
  
