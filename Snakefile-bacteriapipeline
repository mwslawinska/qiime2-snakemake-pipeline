    os.path.join(SCRATCH, "qiime2", "logs", PROJ, PROJ + "_q2_rep_seqs_export.log")
  shell:
    """
    tmpdir=$(dirname {output.rep_seqs_fasta})/.tmp_repseqs_export
    mkdir -p $tmpdir
    qiime tools export \
      --input-path {input.q2_denoised_file} \
      --output-path $tmpdir \
      &> {log}
    mv $tmpdir/dna-sequences.fasta {output.rep_seqs_fasta}
    rm -rf $tmpdir
    """


